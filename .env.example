# Kopieren nach ".env" und mit echten Werten fuellen. ".env" selbst ist
# in .gitignore und wird nie eingecheckt.

POSTGRES_USER=papergene
POSTGRES_PASSWORD=change-me
POSTGRES_DB=papergene

DATABASE_URL=postgresql+psycopg://papergene:change-me@localhost:5432/papergene
REDIS_URL=redis://localhost:6379/0

HTTP_CACHE_PATH=.cache/http_cache.sqlite

# Optional: erhoeht das NCBI-Rate-Limit von 3 auf 10 Anfragen/Sekunde
NCBI_API_KEY=
